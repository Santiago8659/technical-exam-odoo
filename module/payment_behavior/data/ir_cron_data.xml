<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_create_credit_scores" model="ir.cron">
            <field name="name">Create Credit Scores (Batch)</field>
            <field name="model_id" ref="payment_behavior.model_res_partner_credit_score"/>
            <field name="code">model.calculate_credit_scores_batch(batch_size=50)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
        </record>

        <record id="ir_cron_calculate_credit_scores" model="ir.cron">
            <field name="name">Calculate Credit Scores</field>
            <field name="model_id" ref="payment_behavior.model_res_partner_credit_score"/>
            <field name="code">
credit_scores = model.get_credit_score_by_month_year()
if credit_scores:
    batch_size = 20
    for i in range(0, len(credit_scores), batch_size):
        batch_credit_scores = credit_scores[i:i + batch_size]
        try:
            batch_credit_scores.with_delay().calculate_credit_score()
        except:
            batch_credit_scores.calculate_credit_score()
</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
        </record>

        <!-- Payment Behavior Sync - runs before credit score calculation -->
        <record id="ir_cron_calculate_payment_behavior" model="ir.cron">
            <field name="name">Calculate Payment Behavior (Batch)</field>
            <field name="model_id" ref="payment_behavior.model_res_partner"/>
            <field name="code">model._cron_calculate_payment_behavior()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="priority">5</field>
        </record>
    </data>
</odoo>
