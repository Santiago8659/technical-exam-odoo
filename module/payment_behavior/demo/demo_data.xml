<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================
             PAYMENT TERMS
             ============================================ -->
        <record id="payment_term_30_days" model="account.payment.term">
            <field name="name">30 Days</field>
            <field name="note">Payment terms: 30 days</field>
        </record>
        <record id="payment_term_30_days_line" model="account.payment.term.line">
            <field name="payment_id" ref="payment_term_30_days"/>
            <field name="value">balance</field>
            <field name="days">30</field>
            <field name="option">day_after_invoice_date</field>
        </record>

        <record id="payment_term_60_days" model="account.payment.term">
            <field name="name">60 Days</field>
            <field name="note">Payment terms: 60 days</field>
        </record>
        <record id="payment_term_60_days_line" model="account.payment.term.line">
            <field name="payment_id" ref="payment_term_60_days"/>
            <field name="value">balance</field>
            <field name="days">60</field>
            <field name="option">day_after_invoice_date</field>
        </record>

        <!-- ============================================
             TEST PARTNERS (Customers)
             ============================================ -->

        <!-- Partner 1: Good payer - pays on time -->
        <record id="partner_good_payer" model="res.partner">
            <field name="name">Distribuidora El Buen Pago SAS</field>
            <field name="company_type">company</field>
            <field name="email">buenpago@test.com</field>
            <field name="phone">+573001234567</field>
            <field name="property_payment_term_id" ref="payment_term_30_days"/>
            <field name="credit_limit">50000000</field>
            <field name="customer_rank">1</field>
        </record>

        <!-- Partner 2: Late payer - always pays late -->
        <record id="partner_late_payer" model="res.partner">
            <field name="name">Comercializadora Morosa Ltda</field>
            <field name="company_type">company</field>
            <field name="email">morosa@test.com</field>
            <field name="phone">+573009876543</field>
            <field name="property_payment_term_id" ref="payment_term_30_days"/>
            <field name="credit_limit">30000000</field>
            <field name="customer_rank">1</field>
        </record>

        <!-- Partner 3: Mixed payer - sometimes on time, sometimes late -->
        <record id="partner_mixed_payer" model="res.partner">
            <field name="name">Drogueria Mixta SA</field>
            <field name="company_type">company</field>
            <field name="email">mixta@test.com</field>
            <field name="phone">+573005551234</field>
            <field name="property_payment_term_id" ref="payment_term_60_days"/>
            <field name="credit_limit">40000000</field>
            <field name="customer_rank">1</field>
        </record>

        <!-- Partner 4: New partner with no invoices yet -->
        <record id="partner_new_customer" model="res.partner">
            <field name="name">Farmacia Nueva Express</field>
            <field name="company_type">company</field>
            <field name="email">nueva@test.com</field>
            <field name="phone">+573007778899</field>
            <field name="property_payment_term_id" ref="payment_term_30_days"/>
            <field name="credit_limit">20000000</field>
            <field name="customer_rank">1</field>
        </record>

        <!-- Partner 5: Child partner (contact of partner_good_payer) -->
        <record id="partner_good_payer_contact" model="res.partner">
            <field name="name">Juan Perez - Compras</field>
            <field name="parent_id" ref="partner_good_payer"/>
            <field name="type">contact</field>
            <field name="email">juan.perez@buenpago.com</field>
            <field name="phone">+573001234568</field>
        </record>

        <!-- Partner 6: Potential blacklist candidate -->
        <record id="partner_blacklist_candidate" model="res.partner">
            <field name="name">Distribuciones Riesgo Total SAS</field>
            <field name="company_type">company</field>
            <field name="email">riesgo@test.com</field>
            <field name="phone">+573002223344</field>
            <field name="property_payment_term_id" ref="payment_term_30_days"/>
            <field name="credit_limit">15000000</field>
            <field name="customer_rank">1</field>
        </record>

    </data>
</odoo>
